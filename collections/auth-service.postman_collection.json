{
  "info": {
    "name": "AuthService - The5FadeFriends",
    "description": "Colección de endpoints Auth/Users. Registrar en form-data; otros en JSON. Variables: baseUrl, userToken, adminToken.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "e6e1c6f4-0d2b-4f18-9e8b-0000the5fade"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "userToken", "value": "" },
    { "key": "adminToken", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup request (public)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan Perez\",\n  \"email\": \"user@example.com\",\n  \"password\": \"Secret123!\",\n  \"phone\": \"12345678\",\n  \"profilePicture\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/signup-request", "host": ["{{baseUrl}}"], "path": ["auth", "signup-request"] }
          }
        },
        {
          "name": "List signup requests (admin)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ],
            "url": { "raw": "{{baseUrl}}/auth/signup-requests", "host": ["{{baseUrl}}"], "path": ["auth", "signup-requests"] }
          }
        },
        {
          "name": "Approve signup request (admin)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ],
            "url": { "raw": "{{baseUrl}}/auth/signup-requests/<requestId>/approve", "host": ["{{baseUrl}}"], "path": ["auth", "signup-requests", "<requestId>", "approve"] }
          }
        },
        {
          "name": "Register (form-data)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Juan Perez", "type": "text" },
                { "key": "email", "value": "user@example.com", "type": "text" },
                { "key": "password", "value": "Secret123!", "type": "text" },
                { "key": "phone", "value": "12345678", "type": "text" },
                { "key": "profilePicture", "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Secret123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Verify email",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<verification-token>\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/verify-email", "host": ["{{baseUrl}}"], "path": ["auth", "verify-email"] }
          }
        },
        {
          "name": "Resend verification",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/resend-verification", "host": ["{{baseUrl}}"], "path": ["auth", "resend-verification"] }
          }
        },
        {
          "name": "Forgot password",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth", "forgot-password"] }
          }
        },
        {
          "name": "Reset password",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<reset-token>\",\n  \"newPassword\": \"NewPass123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["auth", "reset-password"] }
          }
        },
        {
          "name": "Profile (me)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{userToken}}" } ],
            "url": { "raw": "{{baseUrl}}/auth/profile", "host": ["{{baseUrl}}"], "path": ["auth", "profile"] }
          }
        },
        {
          "name": "Profile by id",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"<user-id>\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/profile/by-id", "host": ["{{baseUrl}}"], "path": ["auth", "profile", "by-id"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Empleado Uno\",\n  \"email\": \"empleado@example.com\",\n  \"password\": \"Secret123!\",\n  \"phone\": \"12345678\",\n  \"profilePicture\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/users/employee", "host": ["{{baseUrl}}"], "path": ["users", "employee"] }
          }
        },
        {
          "name": "Update user role",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleName\": \"EMPLOYEE_ROLE\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/users/<userId>/role", "host": ["{{baseUrl}}"], "path": ["users", "<userId>", "role"] }
          }
        },
        {
          "name": "Get user roles",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{userToken}}" } ],
            "url": { "raw": "{{baseUrl}}/users/<userId>/roles", "host": ["{{baseUrl}}"], "path": ["users", "<userId>", "roles"] }
          }
        },
        {
          "name": "Get users by role",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ],
            "url": { "raw": "{{baseUrl}}/users/by-role/EMPLOYEE_ROLE", "host": ["{{baseUrl}}"], "path": ["users", "by-role", "EMPLOYEE_ROLE"] }
          }
        },
        {
          "name": "Get all users",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{adminToken}}" } ],
            "url": { "raw": "{{baseUrl}}/users/all", "host": ["{{baseUrl}}"], "path": ["users", "all"] }
          }
        }
      ]
    }
  ]
}
